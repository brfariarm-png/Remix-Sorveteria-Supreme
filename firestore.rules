rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedAdmin() {
      return request.auth != null &&
             request.auth.token != null &&
             request.auth.token.email == 'brfariarm@gmail.com';
    }

    // Public test connection endpoint
    match /test/connection {
      allow read: if true;
    }

    // Orders Collection
    match /orders/{orderId} {
      allow create: if true;
      allow read: if isVerifiedAdmin() || (resource != null && (resource.data.ownerId == request.auth.uid || resource.data.ownerId.startsWith('guest-')));
      allow update, delete: if isVerifiedAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // Closeouts Collection
    match /closeouts/{closeoutId} {
      allow read, write: if isVerifiedAdmin();
    }

    // Settings Collection
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isVerifiedAdmin();
    }

    // Menu Items Collection
    match /menu_items/{itemId} {
      allow read: if true;
      allow write: if isVerifiedAdmin();
    }
  }
}
