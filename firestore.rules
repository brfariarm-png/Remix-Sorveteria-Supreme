rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default safety net: deny unrecognized collections
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedAdmin() {
      return request.auth != null &&
             request.auth.token != null &&
             request.auth.token.email == 'brfariarm@gmail.com';
    }

    // Orders Collection
    match /orders/{orderId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isSignedIn();
    }

    // Closeouts Collection
    match /closeouts/{closeoutId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isVerifiedAdmin();
    }

    // Settings Collection
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Menu Items Collection
    match /menu_items/{itemId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
