rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety Net: Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'brfariarm@gmail.com' &&
        request.auth.token.email_verified == true
      );
    }

    // Menu and Options collections: Publicly readable, any authenticated user can write (supports seeding)
    match /menu_items/{itemId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /flavor_options/{optionId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /topping_options/{optionId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Store settings: Publicly readable, Admin writeable
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Cashier closeout reports: Admin only
    match /closeouts/{closeoutId} {
      allow read, write: if isAdmin();
    }

    // Orders: Anyone can create (supports guests), Admin can read/write all, Users/guests can access their own
    match /orders/{orderId} {
      // Anyone can create an order (supports both logged-in and guest checkout)
      allow create: if true;
      
      // Admin can read all orders. Any guest or customer can track a specific order if they know the orderId.
      allow get: if true; 
      
      // Standard query listing: Only admins, or logged-in users querying their own orders
      allow list: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      
      // Update/delete permissions: Admins can update/delete any order. Owners can update their own orders.
      allow update, delete: if isAdmin() || (
        (isSignedIn() && resource.data.ownerId == request.auth.uid) ||
        (resource.data.ownerId == request.resource.data.ownerId)
      );
    }
  }
}
