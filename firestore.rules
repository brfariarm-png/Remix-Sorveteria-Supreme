rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedAdmin() {
      return request.auth != null &&
             request.auth.token != null &&
             request.auth.token.email == 'brfariarm@gmail.com' &&
             request.auth.token.email_verified == true;
    }

    // Public test connection endpoint
    match /test/connection {
      allow read: if true;
    }

    // Orders Collection
    match /orders/{orderId} {
      allow create: if isVerifiedAdmin() || 
                    (isSignedIn() && (
                      request.resource.data.ownerId == request.auth.uid || 
                      (request.resource.data.ownerId is string && request.resource.data.ownerId.matches('^guest-.*'))
                    ));
                    
      allow read: if isVerifiedAdmin() || 
                  (isSignedIn() && (
                    resource == null ||
                    resource.data.ownerId == request.auth.uid || 
                    (resource.data.ownerId is string && resource.data.ownerId.matches('^guest-.*'))
                  ));
                  
      allow update: if isVerifiedAdmin() || 
                    (isSignedIn() && 
                     resource.data.ownerId == request.auth.uid && 
                     request.resource.data.ownerId == resource.data.ownerId &&
                     request.resource.data.createdAt == resource.data.createdAt &&
                     request.resource.data.total == resource.data.total &&
                     (resource.data.status != 'completed' || request.resource.data.status == 'completed')
                    );
                    
      allow delete: if isVerifiedAdmin();
    }

    // Closeouts Collection
    match /closeouts/{closeoutId} {
      allow read, write: if isVerifiedAdmin();
    }

    // Settings Collection
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isVerifiedAdmin();
    }

    // Menu Items Collection
    match /menu_items/{itemId} {
      allow read: if true;
      allow write: if isVerifiedAdmin();
    }
  }
}
