rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Default-Deny Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Public test connection endpoint
    match /test/connection {
      allow read: if true;
    }

    // 2. Helper Primitives
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Include bootstrapped admin based on runtime email
    function isVerifiedAdmin() {
      return request.auth != null &&
             request.auth.token != null &&
             request.auth.token.email == 'brfariarm@gmail.com';
    }

    // 3. Validation Blueprints (Anti-Update-Gap)
    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'ownerId', 'total', 'status', 'timestamp', 'createdAt', 'items', 'details']) 
          && (data.keys().size() == 8 || (data.keys().size() == 9 && data.keys().hasAll(['archived']) && data.archived is bool))
          && data.id is string && data.id.size() <= 64
          && data.ownerId is string && data.ownerId.size() <= 64
          && data.total is number && data.total >= 0.0
          && data.status is string && data.status in ['waiting', 'preparing', 'delivering', 'completed']
          && data.timestamp is string && data.timestamp.size() <= 32
          && data.createdAt == request.time
          && data.items is list && data.items.size() > 0 && data.items.size() <= 100
          && data.details is map;
    }

    function isValidCloseout(data) {
      return data.keys().hasAll(['closedAt', 'closedBy', 'ordersCount', 'totalSales', 'pixSales', 'cardSales', 'cashSales', 'notes', 'orderIds'])
          && data.keys().size() == 9
          && data.closedAt is string && data.closedAt.size() <= 64
          && data.closedBy is string && data.closedBy.size() <= 100
          && data.ordersCount is number && data.ordersCount >= 0
          && data.totalSales is number && data.totalSales >= 0.0
          && data.pixSales is number && data.pixSales >= 0.0
          && data.cardSales is number && data.cardSales >= 0.0
          && data.cashSales is number && data.cashSales >= 0.0
          && data.notes is string && data.notes.size() <= 500
          && data.orderIds is list && data.orderIds.size() <= 1000;
    }

    function isValidStoreSettings(data) {
      return data.keys().hasAll(['name', 'shortName', 'city', 'address', 'phone', 'email'])
          && data.name is string && data.name.size() <= 150
          && data.shortName is string && data.shortName.size() <= 150
          && data.city is string && data.city.size() <= 150
          && data.address is string && data.address.size() <= 400
          && data.phone is string && data.phone.size() <= 100
          && data.email is string && data.email.size() <= 200
          && (!data.keys().hasAll(['updatedAt']) || data.updatedAt is string);
    }

    function isValidMenuItem(data) {
      return data.keys().hasAll(['name', 'description', 'price', 'category', 'image'])
          && data.name is string && data.name.size() <= 200
          && data.description is string && data.description.size() <= 1500
          && data.price is number && data.price >= 0.0
          && data.category is string && data.category in ['acai', 'sorvete', 'milkshake', 'sundae', 'combo']
          && data.image is string && data.image.size() <= 1000000
          && (!data.keys().hasAll(['popular']) || data.popular is bool)
          && (!data.keys().hasAll(['customizable']) || data.customizable is bool)
          && (!data.keys().hasAll(['index']) || data.index is number)
          && (!data.keys().hasAll(['tags']) || data.tags == null || data.tags is list);
    }

    // 4. Access Rules matching blueprint paths
    match /orders/{orderId} {
      // Secure read operations: allow get (by ID) to anyone for instant status updates without authentication limits
      allow get: if true;

      // Allow list only to owners, verified admins, or guests retrieving their guest-prefixed orders
      allow list: if request.auth != null && isVerifiedAdmin()
                  || (request.auth != null && resource.data.ownerId == request.auth.uid)
                  || (resource.data.ownerId is string && resource.data.ownerId.matches('^guest-.*'));

      // Create rule using validation blueprint
      allow create: if isValidId(orderId) 
                    && isValidOrder(incoming());

      // Update rule with action-based diffs and terminal state restrictions
      allow update: if request.auth != null 
                    && (
                      isVerifiedAdmin()
                      || (
                        existing().status != 'completed'
                        && (
                          incoming().diff(existing()).affectedKeys().hasOnly(['status']) 
                          && incoming().status in ['waiting', 'preparing', 'delivering', 'completed']
                        )
                      )
                    );

      // Delete completely forbidden for customers to protect transaction logs
      allow delete: if request.auth != null && isVerifiedAdmin();
    }

    match /closeouts/{closeoutId} {
      allow read: if request.auth != null && isVerifiedAdmin();
      allow create: if request.auth != null && isVerifiedAdmin()
                            && isValidId(closeoutId)
                            && isValidCloseout(incoming());
      allow update, delete: if false;
    }

    match /settings/{settingId} {
      // Configuration settings are publicly readable to boot client app correctly
      allow read: if true;

      // Only authorized admins can change settings
      allow create, update: if isVerifiedAdmin()
                            && isValidId(settingId)
                            && isValidStoreSettings(incoming());

      allow delete: if isVerifiedAdmin();
    }

    match /menu_items/{itemId} {
      // Publicly readable so customers can browse the menu anytime
      allow read: if true;

      // Only authorized admins (including signed-in preview accounts) can manage menu items
      allow create, update: if (isVerifiedAdmin() || isSignedIn())
                            && isValidId(itemId)
                            && isValidMenuItem(incoming());

      allow delete: if isVerifiedAdmin() || isSignedIn();
    }
  }
}
