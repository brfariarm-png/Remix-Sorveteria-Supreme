{
  "id": "/",
  "scope": "/",
  "lang": "pt-BR",
  "dir": "ltr",
  "categories": ["food", "shopping"],
  "short_name": "Supreme",
  "name": "Sorveteria Supreme",
  "description": "App de pedidos online e delivery para a Sorveteria Supreme de Monte Mor/SP. Faça seu açaí ou peça sorvetes artesanais com agilidade e rastreamento em tempo real.",
  "start_url": "/",
  "background_color": "#FFFBFB",
  "theme_color": "#ED2024",
  "display": "standalone",
  "display_override": [
    "standalone",
    "minimal-ui",
    "window-controls-overlay"
  ],
  "orientation": "portrait",
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.supreme.app",
      "id": "com.supreme.app"
    }
  ],
  "iarc_rating_id": "00000000-0000-0000-0000-000000000000",
  "scope_extensions": [
    {
      "origin": "sorveteriasupreme.vercel.app"
    },
    {
      "origin": "*.vercel.app"
    },
    {
      "origin": "*.run.app"
    },
    {
      "origin": "*.us-west2.run.app"
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "edge_side_panel": {
    "preferred_width": 480
  },
  "file_handlers": [
    {
      "action": "/?file",
      "accept": {
        "image/*": [".png", ".jpg", ".jpeg"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+supreme",
      "url": "/?protocol=%s"
    }
  ],
  "widgets": [
    {
      "name": "Sorveteria Supreme",
      "description": "Veja o status do seu pedido na Sorveteria Supreme",
      "tag": "order-status",
      "ms_ac_template": "widgets/status.json",
      "icons": [
        {
          "src": "/assets/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "icons": [
    {
      "src": "/assets/icon-192.png",
      "type": "image/png",
      "sizes": "192x192",
      "purpose": "any"
    },
    {
      "src": "/assets/icon-192.png",
      "type": "image/png",
      "sizes": "192x192",
      "purpose": "maskable"
    },
    {
      "src": "/assets/icon-512.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "any"
    },
    {
      "src": "/assets/icon-512.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "maskable"
    },
    {
      "src": "/assets/apple-touch-icon.png",
      "type": "image/png",
      "sizes": "180x180",
      "purpose": "any"
    }
  ],
  "shortcuts": [
    {
      "name": "Fazer Pedido",
      "short_name": "Cardápio",
      "description": "Abra diretamente o cardápio e monte seu açaí ou peça sorvete artesanal",
      "url": "/?shortcut=order",
      "icons": [
        {
          "src": "/assets/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Meus Pedidos",
      "short_name": "Pedidos",
      "description": "Acompanhe seus pedidos em tempo real",
      "url": "/?shortcut=orders",
      "icons": [
        {
          "src": "/assets/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/?share",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "screenshots": [
    {
      "src": "/assets/images/screenshot_mobile.jpg",
      "sizes": "768x1376",
      "type": "image/jpeg",
      "form_factor": "narrow",
      "label": "Cardápio Interativo no Celular"
    },
    {
      "src": "/assets/images/screenshot_desktop.jpg",
      "sizes": "1376x768",
      "type": "image/jpeg",
      "form_factor": "wide",
      "label": "Acompanhamento e Finalização do Pedido no Computador"
    }
  ]
}
